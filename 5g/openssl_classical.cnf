# OpenSSL configuration for TLS 1.3 with classical key exchange
#
# Used by Open5GS NFs when running in classical mode with OpenSSL 3.5.0.
# Set via: Environment="OPENSSL_CONF=/home/vboxuser/Desktop/PQC/5g/openssl_classical.cnf"
#
# Uses X25519 (classical ECDHE) as the default key exchange group.
# Both client and server load this config, so their preferred groups match
# → no HelloRetryRequest (no extra RTT).

openssl_conf = openssl_init

[openssl_init]
ssl_conf = ssl_configuration
providers = provider_sect

[provider_sect]
default = default_sect

[default_sect]
activate = 1

[ssl_configuration]
system_default = tls_defaults

[tls_defaults]
MinProtocol = TLSv1.3
Groups = X25519
