# OpenSSL configuration for TLS 1.3 with PQC hybrid key exchange
#
# Used by Open5GS NFs when running in PQC mode.
# Set via: Environment="OPENSSL_CONF=/home/vboxuser/Desktop/PQC/5g/openssl_pqc.cnf"
#
# This forces TLS 1.3 minimum and prioritizes X25519MLKEM768 for key exchange.

openssl_conf = openssl_init

[openssl_init]
ssl_conf = ssl_configuration
providers = provider_sect

[provider_sect]
default = default_sect

[default_sect]
activate = 1

[ssl_configuration]
system_default = tls_defaults

[tls_defaults]
MinProtocol = TLSv1.3
Groups = X25519MLKEM768:X25519
